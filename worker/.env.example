# Anthropic — required for the Claude API agent loop
ANTHROPIC_API_KEY=

# Shared secret that authenticates POST /run.
# REQUIRED in production. Generate a fresh secret with one of:
#   openssl rand -hex 32
#   python -c "import secrets; print(secrets.token_hex(32))"
# The same value MUST be set on the web side as WORKER_SHARED_SECRET.
WORKER_SHARED_SECRET=

# Supabase service-role credentials — required in production for step + deliverable persistence.
# Leave both blank in local dev: steps and deliverables fall back to worker/_dev_steps.jsonl.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# DataForSEO — required when real tool executors are wired up
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Optional: override the model used by the agent loop
# CLAUDE_MODEL=claude-opus-4-7
