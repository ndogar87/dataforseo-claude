NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public origin used to build /share/<token> URLs. Set to your real
# https origin in production (e.g. https://app.youragency.com).
NEXT_PUBLIC_APP_URL=

RESEND_API_KEY=
RESEND_FROM=

TRIGGER_DEV_API_KEY=
WORKER_URL=http://localhost:8000

# Shared secret sent as `X-Worker-Secret` to the FastAPI worker. The
# same value MUST be set on the worker as WORKER_SHARED_SECRET.
# Generate a fresh secret with one of:
#   openssl rand -hex 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WORKER_SHARED_SECRET=
