# DataForSEO API credentials
# Sign up at https://dataforseo.com/register (free trial includes $1 credit)
# Then copy this file to .env and fill in your real credentials.
#
# These are the SAME credentials you use to log into the DataForSEO dashboard.
# DataForSEO uses HTTP Basic Auth — your "password" is your API password,
# not your account password (find it in the dashboard).

DATAFORSEO_LOGIN=your_login_email_here
DATAFORSEO_PASSWORD=your_api_password_here

# Optional: change defaults for all skill calls
# DATAFORSEO_LOCATION="United States"
# DATAFORSEO_LANGUAGE="en"
